# =====================================
/public/hot
/public/storage
/public/build
mix-manifest.json

# =====================================
# Testing / Coverage
# =====================================
/coverage
.phpunit.result.cache

# =====================================
# Laravel Sail
# =====================================
/docker-compose.override.yml

